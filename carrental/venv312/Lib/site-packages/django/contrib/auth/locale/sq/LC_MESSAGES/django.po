#: .\venv312\Lib\site-packages\django\contrib\auth\password_validation.py:111
#, python-format
msgid ""
"This password is too short. It must contain at least %(min_length)d "
"character."
msgid_plural ""
"This password is too short. It must contain at least %(min_length)d "
"characters."
msgstr[0] ""
"Ky fjalëkalim është shumë i shkurtër. Duhet të përmbajë të paktën "
"%(min_length)d shenjë."
msgstr[1] ""
"Ky fjalëkalim është shumë i shkurtër. Duhet të përmbajë të paktën "
"%(min_length)d shenja."

#: .\venv312\Lib\site-packages\django\contrib\auth\password_validation.py:123
#, python-format
msgid "Your password must contain at least %(min_length)d character."
msgid_plural "Your password must contain at least %(min_length)d characters."
msgstr[0] "Fjalëkalimi juaj duhet të përmbajë të paktën %(min_length)d shenjë."
msgstr[1] "Fjalëkalimi juaj duhet të përmbajë të paktën %(min_length)d shenja."

#: .\venv312\Lib\site-packages\django\contrib\auth\password_validation.py:206
#, python-format
msgid "The password is too similar to the %(verbose_name)s."
msgstr "Fjalëkalimi është shumë i ngjashëm me %(verbose_name)s."

#: .\venv312\Lib\site-packages\django\contrib\auth\password_validation.py:213
msgid "Your password can’t be too similar to your other personal information."
msgstr ""
"Fjalëkalimi juaj s’mund të jetë shumë i ngjashëm me të dhëna të tjera tuajat "
"personale."

#: .\venv312\Lib\site-packages\django\contrib\auth\password_validation.py:245
msgid "This password is too common."
msgstr "Ky fjalëkalim është shumë i rëndomtë."

#: .\venv312\Lib\site-packages\django\contrib\auth\password_validation.py:250
msgid "Your password can’t be a commonly used password."
msgstr "Fjalëkalimi juaj s’mund të jetë një fjalëkalim i përdorur rëndom."

#: .\venv312\Lib\site-packages\django\contrib\auth\password_validation.py:261
msgid "This password is entirely numeric."
msgstr "Ky fjalëkalim është tërësisht numerik."

#: .\venv312\Lib\site-packages\django\contrib\auth\password_validation.py:266
msgid "Your password can’t be entirely numeric."
msgstr "Fjalëkalimi juaj s’mund të jetë tërësisht numerik."

#: .\venv312\Lib\site-packages\django\contrib\auth\templates\registration\password_reset_subject.txt:2
#, python-format
